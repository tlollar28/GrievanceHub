# GrievanceHub local development environment example
# Copy to .env and replace placeholder values.
# Do not commit real secrets.

# Required for embeddings and LLM-backed analysis / chat
OPENAI_API_KEY=replace_me

# PostgreSQL (matches local docker-compose defaults)
DATABASE_URL=postgresql+psycopg://grievancehub_user:grievancehub_password@localhost:5432/grievancehub

# Interim API-key authentication for /sources routes (fail-closed when unset).
# Prefer Authorization: Bearer <key> or X-API-Key: <key>.
# This is NOT multi-user identity management — replace with a real identity
# provider before internet exposure.
GRIEVANCEHUB_API_KEY=replace_with_long_random_read_key
GRIEVANCEHUB_ADMIN_API_KEY=replace_with_long_random_admin_key

# Optional: only if WeasyPrint cannot locate Pango DLLs on Windows after MSYS2 install
# WEASYPRINT_DLL_DIRECTORIES=C:\msys64\mingw64\bin

# Deployment note: enforce reverse-proxy rate limits on /sources/search/,
# /sources/ask/, and /sources/report/ before any internet exposure. The app
# bounds query length, embeddings, and SQL fan-out, but does not claim
# multi-process request throttling.
